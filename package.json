    "lint": "eslint .",
    "prepublishOnly": "pnpm build"
  },
  "devDependencies": {
    "eslint": "^10.5.0",
    "tsdown": "^0.22.2",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.0",
    "vitest": "^4.1.9"
  }
